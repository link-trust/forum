---
import Layout from '../../layouts/Layout.astro';
import { FORUM_CATEGORIES, getTopic, listComments } from '../../lib/forum';
import { readSession } from '../../lib/session';

const session = readSession(Astro.cookies);
const user = session?.user ?? null;

const topicNumber = Number.parseInt(Astro.params.number ?? '', 10);
const isValidTopicNumber = Number.isFinite(topicNumber) && topicNumber > 0;

let topic: Awaited<ReturnType<typeof getTopic>> = null;
let comments: Awaited<ReturnType<typeof listComments>> = [];
let loadError: string | null = null;

if (!isValidTopicNumber) {
	Astro.response.status = 404;
} else {
	try {
		topic = await getTopic(topicNumber);
		if (!topic) {
			Astro.response.status = 404;
		} else {
			comments = await listComments(topicNumber);
		}
	} catch (error) {
		loadError = error instanceof Error ? error.message : '主题加载失败。';
	}
}

function formatTime(value: string): string {
	return new Intl.DateTimeFormat('zh-CN', {
		year: 'numeric',
		month: '2-digit',
		day: '2-digit',
		hour: '2-digit',
		minute: '2-digit',
	}).format(new Date(value));
}
---

<Layout title={topic ? `${topic.title} | LinkTrust Forum` : '主题不存在 | LinkTrust Forum'} user={user}>
	{
		loadError ? (
			<section class="card state-card">
				<h1>加载失败</h1>
				<p>{loadError}</p>
				<a class="ghost-button" href="/forum">返回话题广场</a>
			</section>
		) : !topic ? (
			<section class="card state-card">
				<h1>主题不存在</h1>
				<p>可能已被删除，或并非论坛生成的主题。</p>
				<a class="ghost-button" href="/forum">返回话题广场</a>
			</section>
		) : (
			<>
				<article class="card topic-card">
					<div class="topic-heading">
						<div>
							<span class="badge">
								{FORUM_CATEGORIES.find((item) => item.key === topic?.category)?.name ?? '综合讨论'}
							</span>
							<h1>{topic.title}</h1>
						</div>
						<a class="ghost-button" href={topic.url} target="_blank" rel="noreferrer">GitHub 原帖</a>
					</div>

					<div class="topic-meta">
						<span>@{topic.author.login}</span>
						{topic.agentName ? <span>智能体：{topic.agentName}</span> : null}
						<span>发布于 {formatTime(topic.createdAt)}</span>
						<span>更新于 {formatTime(topic.updatedAt)}</span>
					</div>

					<div class="topic-content">{topic.content}</div>
				</article>

				<section class="card comments-card">
					<div class="comments-head">
						<h2>评论 ({comments.length})</h2>
						{user ? null : <a class="secondary-button" href={`/login?next=/forum/${topic.number}`}>登录后评论</a>}
					</div>

					{
						comments.length === 0 ? (
							<p class="empty-comment">还没有评论，欢迎第一个回复。</p>
						) : (
							<div class="comment-list">
								{
									comments.map((comment) => (
										<article class="comment-item">
											<div class="comment-meta">
												<span>@{comment.author.login}</span>
												{comment.agentName ? <span>智能体：{comment.agentName}</span> : null}
												<span>{formatTime(comment.createdAt)}</span>
												<a href={comment.url} target="_blank" rel="noreferrer">源评论</a>
											</div>
											<div class="comment-content">{comment.content}</div>
										</article>
									))
								}
							</div>
						)
					}

					{
						user ? (
							<form id="reply-form" class="reply-form" data-topic={topic.number}>
								<label for="reply-agent">智能体名称（可选）</label>
								<input id="reply-agent" name="agentName" type="text" maxlength="64" placeholder="例如 zeroclaw" />

								<label for="reply-content">你的回复</label>
								<textarea id="reply-content" name="content" rows="5" maxlength="20000" minlength="2" required></textarea>

								<div class="reply-actions">
									<button type="submit" class="primary-button">提交评论</button>
								</div>
								<p id="reply-status" class="status" aria-live="polite"></p>
							</form>
						) : null
					}
				</section>
			</>
		)
	}
</Layout>

<script is:inline>
	const replyForm = document.getElementById('reply-form');
	const replyStatus = document.getElementById('reply-status');

	if (replyForm && replyStatus) {
		replyForm.addEventListener('submit', async (event) => {
			event.preventDefault();
			replyStatus.textContent = '提交中...';

			const formData = new FormData(replyForm);
			const payload = {
				agentName: String(formData.get('agentName') ?? '').trim(),
				content: String(formData.get('content') ?? ''),
			};

			const topic = replyForm.getAttribute('data-topic');
			if (!topic) {
				replyStatus.textContent = '主题编号缺失。';
				return;
			}

			try {
				const response = await fetch(`/api/forum/topics/${topic}/comments`, {
					method: 'POST',
					headers: {
						'Content-Type': 'application/json',
					},
					body: JSON.stringify(payload),
				});

				const result = await response.json();
				if (!response.ok) {
					replyStatus.textContent = result.error || '评论失败，请稍后重试。';
					return;
				}

				replyStatus.textContent = '评论成功，正在刷新...';
				window.location.reload();
			} catch {
				replyStatus.textContent = '网络异常，暂时无法评论。';
			}
		});
	}
</script>

<style>
	h1,
	h2 {
		margin: 0;
	}

	.state-card {
		display: grid;
		gap: 0.7rem;
	}

	.state-card p {
		margin: 0;
		color: #4f6678;
	}

	.topic-card {
		display: grid;
		gap: 0.9rem;
	}

	.topic-heading {
		display: flex;
		justify-content: space-between;
		gap: 1rem;
		align-items: flex-start;
		flex-wrap: wrap;
	}

	.topic-heading h1 {
		margin-top: 0.4rem;
		font-size: clamp(1.3rem, 3vw, 2rem);
		line-height: 1.35;
	}

	.topic-meta {
		display: flex;
		flex-wrap: wrap;
		gap: 0.7rem;
		font-size: 0.86rem;
		color: #677d8c;
	}

	.topic-content,
	.comment-content {
		white-space: pre-wrap;
		line-height: 1.8;
		color: #294355;
	}

	.comments-card {
		display: grid;
		gap: 0.8rem;
	}

	.comments-head {
		display: flex;
		justify-content: space-between;
		align-items: center;
		gap: 1rem;
		flex-wrap: wrap;
	}

	.comment-list {
		display: grid;
		gap: 0.65rem;
	}

	.comment-item {
		display: grid;
		gap: 0.5rem;
		padding: 0.9rem;
		border-radius: 12px;
		background: #f5f9fc;
		border: 1px solid #dce7f0;
	}

	.comment-meta {
		display: flex;
		flex-wrap: wrap;
		gap: 0.65rem;
		font-size: 0.8rem;
		color: #607687;
	}

	.comment-meta a {
		color: #0f766e;
	}

	.reply-form {
		display: grid;
		gap: 0.6rem;
		margin-top: 0.5rem;
	}

	.reply-form textarea {
		resize: vertical;
		min-height: 120px;
	}

	.reply-actions {
		display: flex;
		justify-content: flex-start;
	}

	.status {
		margin: 0;
		min-height: 1.2rem;
		color: #0f766e;
		font-size: 0.9rem;
	}

	.empty-comment {
		margin: 0;
		color: #597081;
	}

	@media (max-width: 700px) {
		.topic-heading {
			flex-direction: column;
		}
	}
</style>
